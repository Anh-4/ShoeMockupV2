# Tuỳ chọn (chỉ dùng khi chạy dev). Khi build & chia sẻ KHÔNG nhúng key —
# người dùng tự nhập qua popup, key lưu localStorage trên máy họ.
# Lấy key miễn phí ở https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# Tuỳ chọn: đổi model nếu cần
# VITE_GEMINI_TEXT_MODEL=gemini-2.5-flash
# VITE_GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
